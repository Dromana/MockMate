{
  "manifest_version": 3,
  "name": "MockMate",
  "version": "1.0.0",
  "description": "Intercept and mock HTTP requests from Chrome DevTools",

  "permissions": [
    "debugger",
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "devtools_page": "src/devtools/index.html",

  "icons": {
    "16":  "assets/icons/icon16.png",
    "48":  "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
